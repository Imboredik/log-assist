{
  "manifest_version": 3,
  "name": "LogAssist",
  "version": "1.0",
  "description": "Панель для сбора console и network логов, а также скриншота.",
  "permissions": [
    "scripting",
    "downloads",
    "tabs",
    "activeTab",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:5173/*",
    "https://assist-log.ru/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "camera.png",
        "loading.png",
        "injected.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://assist-log.ru/*"],
      "js": ["content.js"]
    }
  ]
}
